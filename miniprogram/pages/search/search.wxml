<!--search.wxml-->
<navigation-bar title="搜索结果" back="{{true}}" color="black" background="#FFF"></navigation-bar>
<scroll-view class="page" scroll-y type="list">
  <view class="header">
    <text class="header-title">搜索：</text>
    <text class="header-keyword">"{{keyword}}"</text>
    <text class="header-category">分类：{{category}}</text>
  </view>

  <view class="result-list" wx:if="{{results.length > 0}}">
    <view
      class="result-item"
      wx:for="{{results}}"
      wx:key="id"
    >
      <view class="result-icon">{{item.icon}}</view>
      <view class="result-info">
        <text class="result-title">{{item.title}}</text>
        <text class="result-desc">{{item.desc}}</text>
      </view>
      <view class="result-tag">{{item.tag}}</view>
    </view>
  </view>

  <view class="empty-tip" wx:else>
    <text class="empty-emoji">🔍</text>
    <text class="empty-text">未找到相关结果</text>
  </view>
</scroll-view>
