/**search.wxss**/
page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f5f5f5;
}

.page {
  flex: 1;
  padding: 24rpx 32rpx;
}

.header {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 24rpx;
  display: flex;
  flex-wrap: wrap;
  align-items: baseline;
  gap: 12rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.header-title {
  font-size: 28rpx;
  color: #999;
}

.header-keyword {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
}

.header-category {
  font-size: 26rpx;
  color: #667eea;
  background: #ede7f6;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  margin-left: auto;
}

/* 结果列表 */
.result-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding-bottom: 48rpx;
}

.result-item {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.result-icon {
  font-size: 48rpx;
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f8f8f8;
  border-radius: 16rpx;
  margin-right: 20rpx;
}

.result-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.result-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.result-desc {
  font-size: 24rpx;
  color: #999;
}

.result-tag {
  font-size: 24rpx;
  background: #e8f5e9;
  color: #43a047;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
}

/* 空态 */
.empty-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
  gap: 16rpx;
}

.empty-emoji {
  font-size: 80rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #999;
}
