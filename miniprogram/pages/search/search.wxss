/**search.wxss**/
page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f5f6fa;
}

.page {
  flex: 1;
  display: flex;
  flex-direction: column;
  padding: 24rpx 24rpx 0;
}

/* 搜索条 */
.search-bar {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 40rpx;
  padding: 16rpx 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.search-icon {
  font-size: 38rpx;
  margin-right: 16rpx;
}

.search-input {
  flex: 1;
  font-size: 32rpx;
  color: #333;
  height: 72rpx;
  line-height: 72rpx;
}

.ph {
  color: #bbb;
}

.search-clear {
  font-size: 28rpx;
  color: #bbb;
  padding: 0 12rpx;
}

.search-btn {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  font-size: 28rpx;
  padding: 14rpx 32rpx;
  border-radius: 50rpx;
  margin-left: 12rpx;
  border: none;
  transition: all 0.1s;
}

.search-btn.s-pressed {
  transform: scale(0.95);
  box-shadow: inset 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
}

@keyframes s-shake {
  0%, 100% { transform: scale(0.95) translateX(0); }
  15% { transform: scale(0.95) translateX(-3rpx); }
  35% { transform: scale(0.95) translateX(3rpx); }
  55% { transform: scale(0.95) translateX(-2rpx); }
  75% { transform: scale(0.95) translateX(2rpx); }
  90% { transform: scale(0.95) translateX(-1rpx); }
}

.search-btn.s-shaking {
  animation: s-shake 0.35s ease;
}

/* 搜索结果 */
.result-scroll {
  flex: 1;
  overflow-y: hidden;
}

.result-list {
  padding-bottom: 48rpx;
}

.result-item {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 18rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.play-btn {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #ff7e5f, #feb47b);
  color: #fff;
  font-size: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.result-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  min-width: 0;
}

.result-title {
  font-size: 34rpx;
  color: #222;
  font-weight: 600;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.result-desc {
  font-size: 24rpx;
  color: #999;
}

.result-tag {
  font-size: 24rpx;
  color: #ff7e5f;
  background: rgba(255, 126, 95, 0.1);
  padding: 6rpx 18rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
  margin-left: 12rpx;
}

/* 收藏按钮 */
.fav-btn {
  font-size: 32rpx;
  padding: 4rpx 8rpx;
  transition: transform 0.2s;
  flex-shrink: 0;
}
.fav-btn:active {
  transform: scale(1.3);
}
.fav-btn.fav-on {
  animation: heartPop 0.3s ease;
}
@keyframes heartPop {
  0% { transform: scale(1); }
  50% { transform: scale(1.4); }
  100% { transform: scale(1); }
}

/* 空态 */
.empty-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 160rpx;
  gap: 16rpx;
}

.empty-emoji {
  font-size: 80rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #999;
}

/* 搜索前提示 */
.search-hint {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  padding-bottom: 120rpx;
}

.hint-emoji {
  font-size: 96rpx;
  opacity: 0.4;
}

.hint-text {
  font-size: 28rpx;
  color: #bbb;
}
