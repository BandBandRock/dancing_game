<!--rank.wxml-->
<navigation-bar title="排名" back="{{true}}" color="black" background="#FFF"></navigation-bar>
<scroll-view class="page" scroll-y type="list">
  <!-- 排名切换 -->
  <view class="tabs">
    <view class="tab {{tabIndex === 0 ? 'tab-active' : ''}} {{shaking.duration ? 'pressed shaking' : ''}}" bindtap="switchDuration" data-index="0">
      <text>🏆 跳舞时长</text>
    </view>
    <view class="tab {{tabIndex === 1 ? 'tab-active' : ''}} {{shaking.score ? 'pressed shaking' : ''}}" bindtap="switchScore" data-index="1">
      <text>⭐ 标准分数</text>
    </view>
  </view>

  <!-- 我的排名卡片 -->
  <view class="my-rank-card">
    <text class="my-rank-label">我的排名</text>
    <text class="my-rank-num">#{{myRank}}</text>
  </view>

  <!-- 排名列表 -->
  <view class="rank-list">
    <view
      class="rank-item {{item.id === 1 ? 'rank-top' : ''}}"
      wx:for="{{displayList}}"
      wx:key="id"
    >
      <view class="rank-num-col">
        <text class="rank-num" wx:if="{{item.rank === 1}}">🥇</text>
        <text class="rank-num" wx:elif="{{item.rank === 2}}">🥈</text>
        <text class="rank-num" wx:elif="{{item.rank === 3}}">🥉</text>
        <text class="rank-num rank-num-text" wx:else>{{item.rank}}</text>
      </view>
      <view class="rank-avatar" style="background:{{item.avatar}}">
        <text class="avatar-text">{{item.name[0]}}</text>
      </view>
      <view class="rank-info">
        <text class="rank-name">{{item.name}}</text>
        <text class="rank-sub">{{item.style}} · {{item.level}}</text>
      </view>
      <view class="rank-score">
        <text class="score-main">{{item.displayValue}}</text>
        <text class="score-unit">{{item.unit}}</text>
      </view>
    </view>
  </view>
</scroll-view>
