/**rank.wxss**/
page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f5f5f5;
}

.page {
  flex: 1;
  padding: 24rpx 32rpx;
}

/* 切换标签 */
.tabs {
  display: flex;
  gap: 20rpx;
  margin-bottom: 28rpx;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 30rpx;
  font-weight: 600;
  color: #666;
  background: #fff;
  border-radius: 16rpx;
  border-bottom: 8rpx solid rgba(0, 0, 0, 0.15);
  box-shadow:
    0 8rpx 0 rgba(0, 0, 0, 0.15),
    0 10rpx 24rpx rgba(0, 0, 0, 0.08);
  transform: translateY(0);
  transition: all 0.1s;
}

.tab.pressed {
  border-bottom: 4rpx solid rgba(0, 0, 0, 0.12);
  box-shadow:
    0 4rpx 0 rgba(0, 0, 0, 0.12),
    0 5rpx 12rpx rgba(0, 0, 0, 0.06);
  transform: translateY(4rpx);
}

.tab-active {
  color: #fff;
  background: linear-gradient(135deg, #667eea, #764ba2);
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.3);
  border-bottom: 6rpx solid rgba(0, 0, 0, 0.2);
}

.tab-active.pressed {
  border-bottom: 3rpx solid rgba(0, 0, 0, 0.15);
  box-shadow:
    0 3rpx 0 rgba(0, 0, 0, 0.15),
    0 4rpx 10rpx rgba(102, 126, 234, 0.2);
  transform: translateY(3rpx);
}

/* 点击抖动 */
@keyframes shake {
  0%, 100% { transform: translateY(4rpx) translateX(0); }
  15% { transform: translateY(4rpx) translateX(-4rpx); }
  35% { transform: translateY(4rpx) translateX(4rpx); }
  55% { transform: translateY(4rpx) translateX(-3rpx); }
  75% { transform: translateY(4rpx) translateX(3rpx); }
  90% { transform: translateY(4rpx) translateX(-1rpx); }
}

.tab.shaking {
  animation: shake 0.35s ease;
}

.tab-active.shaking {
  animation-name: shake;
}

/* 我的排名 */
.my-rank-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: linear-gradient(135deg, #ffd54f, #ffb300);
  border-radius: 20rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(255, 179, 0, 0.3);
}

.my-rank-label {
  font-size: 30rpx;
  font-weight: 600;
  color: #5d4037;
}

.my-rank-num {
  font-size: 48rpx;
  font-weight: 800;
  color: #5d4037;
}

/* 排名列表 */
.rank-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding-bottom: 48rpx;
}

.rank-item {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.rank-item.rank-top {
  background: linear-gradient(135deg, #fffde7, #fff9c4);
  border: 2rpx solid #ffe082;
}

.rank-num-col {
  width: 70rpx;
  text-align: center;
}

.rank-num {
  font-size: 44rpx;
}

.rank-num-text {
  font-size: 32rpx;
  font-weight: 700;
  color: #999;
}

.rank-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin: 0 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-text {
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
}

.rank-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.rank-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.rank-sub {
  font-size: 24rpx;
  color: #999;
}

.rank-score {
  display: flex;
  align-items: baseline;
  gap: 6rpx;
}

.score-main {
  font-size: 36rpx;
  font-weight: 700;
  color: #667eea;
}

.score-unit {
  font-size: 24rpx;
  color: #999;
}
