<view class="page">
  <view class="title">上传视频到云存储</view>

  <!-- 预览区 -->
  <view class="preview" wx:if="{{tempFilePath}}">
    <video class="video" src="{{tempFilePath}}" controls></video>
    <view class="meta">时长 {{duration}}s · 大小 {{size}} 字节</view>
  </view>
  <view class="placeholder" wx:else>还没有选择视频</view>

  <!-- 进度条 -->
  <view class="progress" wx:if="{{uploading}}">
    <view class="progress-bar" style="width: {{percent}}%;"></view>
    <text class="progress-text">{{percent}}%</text>
  </view>

  <!-- 操作按钮 -->
  <view class="btns">
    <button class="btn" bindtap="chooseVideo" disabled="{{uploading}}">选择视频</button>
    <button class="btn primary" bindtap="startUpload" disabled="{{uploading || !tempFilePath}}">开始上传</button>
  </view>

  <!-- 结果 -->
  <view class="result" wx:if="{{resultUrl || resultFileID}}">
    <view class="result-title">上传成功</view>
    <view class="result-label">fileID（可复用于云存储加载）：</view>
    <view class="result-url" bindtap="copyFileID">{{resultFileID}}</view>
    <view class="result-label">临时播放地址（约 2 小时有效）：</view>
    <view class="result-url" bindtap="copyUrl">{{resultUrl}}</view>
    <view class="result-tip">点击对应地址可复制</view>
  </view>
</view>
