.page {
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.title {
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.preview {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.video {
  width: 100%;
  height: 420rpx;
  border-radius: 16rpx;
  background: #000;
}

.meta {
  font-size: 24rpx;
  color: #888;
}

.placeholder {
  height: 420rpx;
  border-radius: 16rpx;
  background: #f2f2f2;
  color: #aaa;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.progress {
  position: relative;
  height: 32rpx;
  border-radius: 16rpx;
  background: #eee;
  overflow: hidden;
}

.progress-bar {
  height: 100%;
  background: #07c160;
  transition: width 0.2s ease;
}

.progress-text {
  position: absolute;
  right: 12rpx;
  top: 0;
  line-height: 32rpx;
  font-size: 22rpx;
  color: #333;
}

.btns {
  display: flex;
  gap: 24rpx;
}

.btn {
  flex: 1;
  font-size: 30rpx;
}

.btn.primary {
  background: #07c160;
  color: #fff;
}

.result {
  padding: 24rpx;
  border-radius: 16rpx;
  background: #f7f7f7;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.result-title {
  font-size: 28rpx;
  font-weight: 600;
}

.result-url {
  font-size: 24rpx;
  color: #576b95;
  word-break: break-all;
}

.result-tip {
  font-size: 22rpx;
  color: #aaa;
}
