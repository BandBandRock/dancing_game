/* pages/pose/pose.wxss */
.page {
  position: relative;
  width: 100vw;
  height: 100vh;
  background: #000;
  overflow: hidden;
}

/* 主体：教学视频（铺满） */
.main-video {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.main-empty {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.main-empty-text {
  color: #666;
  font-size: 30rpx;
}

/* 右下角摄像头小窗（约屏幕 1/3 宽） */
.cam-float {
  position: absolute;
  right: 24rpx;
  bottom: 40rpx;
  width: 34vw;
  height: 48vw;
  border-radius: 20rpx;
  overflow: hidden;
  z-index: 10;
  background: #111;
  box-shadow: 0 6rpx 24rpx rgba(0, 0, 0, 0.5);
  border: 2rpx solid rgba(255, 255, 255, 0.15);
  /* 识别成功后从全屏平滑收缩到右下角小窗，给用户一个过渡预期 */
  transition: right 0.45s cubic-bezier(0.22, 1, 0.36, 1),
              bottom 0.45s cubic-bezier(0.22, 1, 0.36, 1),
              width 0.45s cubic-bezier(0.22, 1, 0.36, 1),
              height 0.45s cubic-bezier(0.22, 1, 0.36, 1),
              border-radius 0.45s ease;
}

.camera {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.skeleton {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
}

.cam-hud {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  padding: 10rpx 14rpx;
  background: linear-gradient(180deg, rgba(0, 0, 0, 0.55), rgba(0, 0, 0, 0));
  display: flex;
  flex-direction: column;
  gap: 2rpx;
}

.cam-hud-text {
  color: #fff;
  font-size: 20rpx;
  line-height: 1.3;
  text-shadow: 0 1px 2px rgba(0, 0, 0, 0.6);
}

.cam-hud-sub {
  color: #5dcaa5;
  font-size: 20rpx;
}

.cam-mirror {
  position: absolute;
  bottom: 10rpx;
  right: 10rpx;
  padding: 6rpx 16rpx;
  background: rgba(0, 0, 0, 0.5);
  color: #fff;
  font-size: 20rpx;
  border-radius: 20rpx;
}

/* 对齐阶段：相机小窗变全屏 */
.cam-float.cam-full {
  right: 0;
  bottom: 0;
  width: 100vw;
  height: 100vh;
  border-radius: 0;
  box-shadow: none;
  border: none;
  z-index: 5;
}

/* 对齐阶段覆盖层（在相机之上） */
.align-overlay {
  position: fixed;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  z-index: 12;
  pointer-events: none;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.align-tip {
  margin-top: calc(env(safe-area-inset-top) + 40rpx);
  padding: 16rpx 36rpx;
  background: rgba(0, 0, 0, 0.55);
  color: #fff;
  font-size: 30rpx;
  border-radius: 30rpx;
  text-align: center;
}

.align-tip.align-tip-ok {
  background: rgba(52, 199, 89, 0.85);
}

.align-bar {
  position: absolute;
  left: 50%;
  bottom: calc(env(safe-area-inset-bottom) + 120rpx);
  transform: translateX(-50%);
  width: 60vw;
  height: 18rpx;
  border-radius: 10rpx;
  background: rgba(255, 255, 255, 0.25);
  overflow: hidden;
}

.align-fill {
  height: 100%;
  border-radius: 10rpx;
  background: linear-gradient(90deg, #34C759, #30D158);
  transition: width 0.12s linear;
}

.align-pct {
  position: absolute;
  left: 50%;
  bottom: calc(env(safe-area-inset-bottom) + 150rpx);
  transform: translateX(-50%);
  color: #fff;
  font-size: 26rpx;
  font-weight: 700;
  text-shadow: 0 1px 3px rgba(0, 0, 0, 0.6);
}

/* 左上角返回按钮 */
.back-btn {
  position: absolute;
  top: calc(env(safe-area-inset-top) + 16rpx);
  left: 24rpx;
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 20;
}

.back-btn-active {
  background: rgba(0, 0, 0, 0.7);
}

.back-icon {
  color: #fff;
  font-size: 52rpx;
  line-height: 1;
  margin-top: -6rpx;
}

/* 顶部歌名 */
.song-tag {
  position: absolute;
  top: calc(env(safe-area-inset-top) + 20rpx);
  left: 50%;
  transform: translateX(-50%);
  max-width: 60vw;
  padding: 10rpx 28rpx;
  background: rgba(0, 0, 0, 0.4);
  border-radius: 30rpx;
  z-index: 15;
}

.song-tag-text {
  color: #fff;
  font-size: 28rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* 得分进度条 */
.score-panel {
  position: absolute;
  top: calc(env(safe-area-inset-top) + 96rpx);
  left: 50%;
  transform: translateX(-50%);
  width: 62vw;
  padding: 16rpx 24rpx;
  background: rgba(0, 0, 0, 0.4);
  border-radius: 20rpx;
  z-index: 15;
  box-sizing: border-box;
}

.score-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 10rpx;
}

.score-label {
  color: #fff;
  font-size: 24rpx;
}

.score-value {
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1;
  transition: color 0.3s;
}

.score-up {
  color: #5dcaa5;
}

.score-down {
  color: #ff7e5f;
}

.score-bar {
  width: 100%;
  height: 16rpx;
  border-radius: 10rpx;
  background: rgba(255, 255, 255, 0.2);
  overflow: hidden;
}

.score-fill {
  height: 100%;
  border-radius: 10rpx;
  background: linear-gradient(90deg, #5dcaa5, #3bb2b8);
  transition: width 0.5s ease;
}

.score-hint {
  display: block;
  margin-top: 8rpx;
  color: rgba(255, 255, 255, 0.85);
  font-size: 20rpx;
}

/* 不支持降级 */
.unsupported {
  position: absolute;
  top: 40%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 80%;
  text-align: center;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.unsupported-title {
  color: #fff;
  font-size: 32rpx;
}

.unsupported-desc {
  color: #aaa;
  font-size: 26rpx;
}

/* 开始跳舞遮罩 */
.start-mask {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.55);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 30;
}
.start-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
  padding: 60rpx 70rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 28rpx;
}
.start-title {
  color: #fff;
  font-size: 44rpx;
  font-weight: 700;
}
.start-sub {
  color: rgba(255, 255, 255, 0.8);
  font-size: 28rpx;
}
.start-btn {
  margin-top: 20rpx;
  padding: 24rpx 90rpx;
  background: linear-gradient(135deg, #ff7e5f, #feb47b);
  color: #fff;
  font-size: 38rpx;
  font-weight: 700;
  border-radius: 50rpx;
  box-shadow: 0 8rpx 24rpx rgba(255, 126, 95, 0.4);
}
.start-btn-active {
  transform: scale(0.96);
  opacity: 0.9;
}

/* 结束跳舞按钮 */
.end-btn {
  position: absolute;
  left: 50%;
  bottom: calc(env(safe-area-inset-bottom) + 60rpx);
  transform: translateX(-50%);
  padding: 24rpx 100rpx;
  background: rgba(230, 67, 64, 0.92);
  color: #fff;
  font-size: 36rpx;
  font-weight: 700;
  border-radius: 50rpx;
  z-index: 30;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.3);
}
.end-btn-active {
  transform: translateX(-50%) scale(0.96);
  opacity: 0.9;
}

/* 倍速选择栏 */
.speed-panel {
  position: absolute;
  left: 32rpx;
  bottom: 120rpx;
  display: flex;
  gap: 16rpx;
  z-index: 20;
  padding: 14rpx 24rpx;
  background: rgba(0, 0, 0, 0.45);
  border-radius: 40rpx;
}

.speed-tag {
  padding: 10rpx 26rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.75);
  background: rgba(255, 255, 255, 0.12);
  border-radius: 28rpx;
  transition: background 0.15s, transform 0.12s, color 0.15s;
}

.speed-tag.tag-hover {
  color: #fff;
  background: rgba(255, 255, 255, 0.28);
  transform: scale(1.08);
}

.speed-tag.speed-tag-on {
  color: #fff;
  background: linear-gradient(135deg, #667eea, #764ba2);
  box-shadow: 0 2rpx 10rpx rgba(102, 126, 234, 0.4);
}

.speed-tag.speed-tag-on.tag-hover {
  background: linear-gradient(135deg, #8878ff, #9a6bc0);
}

/* 颤动动画 */
@keyframes tagShake {
  0%, 100% { transform: translateX(0); }
  15%      { transform: translateX(-3rpx); }
  35%      { transform: translateX(3rpx); }
  55%      { transform: translateX(-2rpx); }
  75%      { transform: translateX(2rpx); }
  90%      { transform: translateX(-1rpx); }
}
.tag-shake {
  animation: tagShake 0.35s ease;
}

/* 连续多人/缺帧：屏幕边缘红色渐变闪烁告警 */
.warn-flash {
  position: fixed;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
  z-index: 40;
  border: 10rpx solid rgba(255, 59, 48, 0.2);
  animation: warnPulse 1s ease-in-out infinite;
}

@keyframes warnPulse {
  0%, 100% { box-shadow: inset 0 0 0rpx rgba(255, 59, 48, 0);     border-color: rgba(255, 59, 48, 0.15); }
  50%      { box-shadow: inset 0 0 90rpx rgba(255, 59, 48, 0.6);  border-color: rgba(255, 59, 48, 0.85); }
}

.warn-tip {
  position: fixed;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  z-index: 41;
  padding: 20rpx 40rpx;
  background: rgba(0, 0, 0, 0.6);
  color: #fff;
  font-size: 30rpx;
  border-radius: 16rpx;
  pointer-events: none;
  text-align: center;
}

/* 礼花 canvas 全屏覆盖 */
.fire-canvas {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  z-index: 25;
}

/* 你真棒文字 */
.praise-text {
  position: absolute;
  top: 55%;
  left: 50%;
  transform: translateX(-50%);
  font-size: 60rpx;
  font-weight: 900;
  color: #FFD700;
  text-shadow: 0 0 20rpx rgba(255,215,0,0.6), 0 4rpx 12rpx rgba(0,0,0,0.3);
  z-index: 26;
  animation: praiseFadeIn 0.5s ease, praisePulse 1s ease 0.5s infinite alternate;
}
@keyframes praiseFadeIn {
  0% { opacity: 0; transform: translateX(-50%) scale(0.3); }
  100% { opacity: 1; transform: translateX(-50%) scale(1); }
}
@keyframes praisePulse {
  0% { transform: translateX(-50%) scale(1); }
  100% { transform: translateX(-50%) scale(1.1); }
}

/* 3-2-1 倒计时遮罩 */
.count-overlay {
  position: fixed;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  z-index: 50;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.35);
  pointer-events: none;
}
.count-num {
  font-size: 220rpx;
  font-weight: 900;
  color: #fff;
  line-height: 1;
  text-shadow: 0 6rpx 30rpx rgba(0, 0, 0, 0.5);
  animation: countPop 0.95s ease;
}
.count-tip {
  margin-top: 20rpx;
  font-size: 34rpx;
  color: rgba(255, 255, 255, 0.9);
}
@keyframes countPop {
  0%   { transform: scale(0.4); opacity: 0; }
  30%  { transform: scale(1.1); opacity: 1; }
  70%  { transform: scale(1);   opacity: 1; }
  100% { transform: scale(0.85); opacity: 0.15; }
}
