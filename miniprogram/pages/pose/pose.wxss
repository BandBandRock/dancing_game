/* pages/pose/pose.wxss */
.page {
  position: relative;
  width: 100vw;
  height: 100vh;
  background: #000;
  overflow: hidden;
}

/* 主体：教学视频（铺满） */
.main-video {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.main-empty {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.main-empty-text {
  color: #666;
  font-size: 30rpx;
}

/* 右下角摄像头小窗（约屏幕 1/3 宽） */
.cam-float {
  position: absolute;
  right: 24rpx;
  bottom: 40rpx;
  width: 34vw;
  height: 48vw;
  border-radius: 20rpx;
  overflow: hidden;
  z-index: 10;
  background: #111;
  box-shadow: 0 6rpx 24rpx rgba(0, 0, 0, 0.5);
  border: 2rpx solid rgba(255, 255, 255, 0.15);
}

.camera {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.skeleton {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
}

.cam-hud {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  padding: 10rpx 14rpx;
  background: linear-gradient(180deg, rgba(0, 0, 0, 0.55), rgba(0, 0, 0, 0));
  display: flex;
  flex-direction: column;
  gap: 2rpx;
}

.cam-hud-text {
  color: #fff;
  font-size: 20rpx;
  line-height: 1.3;
  text-shadow: 0 1px 2px rgba(0, 0, 0, 0.6);
}

.cam-hud-sub {
  color: #5dcaa5;
  font-size: 20rpx;
}

.cam-mirror {
  position: absolute;
  bottom: 10rpx;
  right: 10rpx;
  padding: 6rpx 16rpx;
  background: rgba(0, 0, 0, 0.5);
  color: #fff;
  font-size: 20rpx;
  border-radius: 20rpx;
}

/* 左上角返回按钮 */
.back-btn {
  position: absolute;
  top: calc(env(safe-area-inset-top) + 16rpx);
  left: 24rpx;
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 20;
}

.back-btn-active {
  background: rgba(0, 0, 0, 0.7);
}

.back-icon {
  color: #fff;
  font-size: 52rpx;
  line-height: 1;
  margin-top: -6rpx;
}

/* 顶部歌名 */
.song-tag {
  position: absolute;
  top: calc(env(safe-area-inset-top) + 20rpx);
  left: 50%;
  transform: translateX(-50%);
  max-width: 60vw;
  padding: 10rpx 28rpx;
  background: rgba(0, 0, 0, 0.4);
  border-radius: 30rpx;
  z-index: 15;
}

.song-tag-text {
  color: #fff;
  font-size: 28rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* 不支持降级 */
.unsupported {
  position: absolute;
  top: 40%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 80%;
  text-align: center;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.unsupported-title {
  color: #fff;
  font-size: 32rpx;
}

.unsupported-desc {
  color: #aaa;
  font-size: 26rpx;
}
