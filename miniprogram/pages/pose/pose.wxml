<!--pages/pose/pose.wxml-->
<view class="page">
  <!-- 主体：教学视频（从搜索页「去跳舞」带入） -->
  <video
    wx:if="{{danceVideo}}"
    class="main-video"
    src="{{danceVideo}}"
    autoplay="{{true}}"
    controls="{{true}}"
    show-center-play-btn="{{true}}"
    object-fit="contain"
    loop="{{true}}"
  ></video>
  <view wx:else class="main-empty">
    <text class="main-empty-text">未选择教学视频</text>
  </view>

  <!-- 左上角返回入口 -->
  <view class="back-btn" hover-class="back-btn-active" bindtap="goBack">
    <text class="back-icon">‹</text>
  </view>

  <!-- 顶部歌名 -->
  <view wx:if="{{songName}}" class="song-tag">
    <text class="song-tag-text">{{songName}}</text>
  </view>

  <!-- 得分进度条 -->
  <view class="score-panel">
    <view class="score-head">
      <text class="score-label">得分</text>
      <text class="score-value {{moving ? 'score-up' : 'score-down'}}">{{score}}</text>
    </view>
    <view class="score-bar">
      <view class="score-fill" style="width: {{score}}%"></view>
    </view>
    <text class="score-hint">{{moving ? '动起来啦，加分！' : '跳起来才能加分哦'}}</text>
  </view>

  <!-- 右下角摄像头小窗 + 骨骼识别 -->
  <view class="cam-float">
    <camera
      wx:if="{{cameraReady}}"
      class="camera"
      device-position="front"
      flash="off"
      frame-size="medium"
      binderror="onCameraError"
    ></camera>
    <canvas
      type="2d"
      id="skeleton"
      class="skeleton"
      disable-scroll="{{true}}"
    ></canvas>

    <!-- 小窗内状态条 -->
    <view class="cam-hud">
      <text class="cam-hud-text">{{statusText}}</text>
      <text wx:if="{{bodyCount > 0 || fps > 0}}" class="cam-hud-sub">{{bodyCount}}人 · {{fps}}FPS</text>
    </view>

    <!-- 镜像切换 -->
    <view class="cam-mirror" catchtap="toggleMirror">{{mirror ? '镜像开' : '镜像关'}}</view>
  </view>

  <!-- 不支持时的降级提示 -->
  <view wx:if="{{!supported}}" class="unsupported">
    <text class="unsupported-title">当前设备暂不支持实时姿态识别</text>
    <text class="unsupported-desc">{{unsupportedReason}}</text>
  </view>
</view>
