<!--pages/pose/pose.wxml-->
<view class="page">
  <!-- 主体：教学视频（从搜索页「去跳舞」带入） -->
  <video
    wx:if="{{danceVideo}}"
    id="danceVideo"
    class="main-video"
    src="{{danceVideo}}"
    autoplay="{{false}}"
    controls="{{true}}"
    show-center-play-btn="{{true}}"
    object-fit="contain"
    loop="{{false}}"
    playback-rate="{{rate}}"
    bindended="onVideoEnded"
  ></video>

  <!-- 礼花 canvas 层 -->
  <canvas
    type="2d"
    id="fireCanvas"
    class="fire-canvas"
    hidden="{{!fireworkActive}}"
  ></canvas>
  <view wx:if="{{showPraise}}" class="praise-text">你真棒</view>

  <!-- 倍速选择栏 -->
  <view wx:if="{{danceVideo}}" class="speed-panel">
    <view
      class="speed-tag {{rate === 0.5 ? 'speed-tag-on' : ''}} {{shaking.s05 ? 'tag-shake' : ''}}"
      hover-class="tag-hover"
      bindtap="setRate"
      data-rate="0.5"
    >0.5x</view>
    <view
      class="speed-tag {{rate === 1 ? 'speed-tag-on' : ''}} {{shaking.s1 ? 'tag-shake' : ''}}"
      hover-class="tag-hover"
      bindtap="setRate"
      data-rate="1"
    >1x</view>
  </view>
  <view wx:else class="main-empty">
    <text class="main-empty-text">未选择教学视频</text>
  </view>

  <!-- 左上角返回入口 -->
  <view class="back-btn" hover-class="back-btn-active" bindtap="goBack">
    <text class="back-icon">‹</text>
  </view>

  <!-- 顶部歌名 -->
  <view wx:if="{{songName}}" class="song-tag">
    <text class="song-tag-text">{{songName}}</text>
  </view>

  <!-- 得分进度条（跳舞中显示） -->
  <view wx:if="{{started}}" class="score-panel">
    <view class="score-head">
      <text class="score-label">平均分</text>
      <text class="score-value {{moving ? 'score-up' : 'score-down'}}">{{score}}</text>
    </view>
    <view class="score-bar">
      <view class="score-fill" style="width: {{score}}%"></view>
    </view>
    <text class="score-hint">{{moving ? '动起来啦，加分！' : '跳起来才能加分哦'}}</text>
  </view>

  <!-- 右下角摄像头小窗 + 骨骼识别 -->
  <view class="cam-float">
    <camera
      wx:if="{{cameraReady}}"
      class="camera"
      device-position="front"
      flash="off"
      frame-size="medium"
      binderror="onCameraError"
    ></camera>
    <canvas
      type="2d"
      id="skeleton"
      class="skeleton"
      disable-scroll="{{true}}"
    ></canvas>

    <!-- 小窗内状态条 -->
    <view class="cam-hud">
      <text class="cam-hud-text">{{statusText}}</text>
      <text wx:if="{{bodyCount > 0 || fps > 0}}" class="cam-hud-sub">{{bodyCount}}人 · {{fps}}FPS</text>
    </view>

    <!-- 镜像切换 -->
    <view class="cam-mirror" catchtap="toggleMirror">{{mirror ? '镜像开' : '镜像关'}}</view>
  </view>

  <!-- 不支持时的降级提示 -->
  <view wx:if="{{!supported}}" class="unsupported">
    <text class="unsupported-title">当前设备暂不支持实时姿态识别</text>
    <text class="unsupported-desc">{{unsupportedReason}}</text>
  </view>

  <!-- 开始跳舞遮罩（未开始时显示） -->
  <view wx:if="{{!started}}" class="start-mask">
    <view class="start-card">
      <text class="start-title">{{songName || '广场舞'}}</text>
      <text class="start-sub">准备好就开始跳吧</text>
      <view class="start-btn" hover-class="start-btn-active" bindtap="startDance">开始跳舞</view>
    </view>
  </view>

  <!-- 结束跳舞按钮（跳舞中显示） -->
  <view wx:if="{{started && !ended}}" class="end-btn" hover-class="end-btn-active" bindtap="finishDance">结束跳舞</view>
</view>
