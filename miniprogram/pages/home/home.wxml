<!--home.wxml-->
<navigation-bar title="首页" back="{{false}}" color="black" background="#FFF"></navigation-bar>
<view class="page">
  <!-- 搜索条 -->
  <view class="search-bar">
    <text class="search-icon">🔍</text>
    <input class="search-input" placeholder="搜索歌曲 / 歌手 / 类型" bindinput="onSearchInput" value="{{keyword}}" confirm-type="search" bindconfirm="doSearch" />
    <text wx:if="{{keyword}}" class="search-clear" bindtap="onClear">✕</text>
    <button class="search-btn {{shaking.search ? 's-pressed s-shaking' : ''}}" bindtap="doSearch">搜索</button>
  </view>

  <!-- 关键词不为空 → 拆行：有结果则显示列表，否则提示；大于 1 行时收起 4 个分类大按钮 -->
  <block wx:if="{{keyword}}">
    <view class="search-results" wx:if="{{filtered.length > 0}}">
      <view
        class="search-item"
        wx:for="{{filtered}}"
        wx:key="name"
        bindtap="onResultTap"
        data-name="{{item.name}}"
      >
        <view class="search-item-play">▶</view>
        <view class="search-item-info">
          <text class="search-item-name">{{item.name}}</text>
          <text class="search-item-sub">{{item.artist}} · {{item.duration}}</text>
        </view>
        <text class="search-item-type">{{item.type}}</text>
      </view>
    </view>
    <view class="search-empty" wx:else>
      <text class="search-empty-text">没有找到相关歌曲</text>
    </view>
  </block>

  <!-- 关键词为空时才显示 4 个分类大按钮 + 下方导航行 -->
  <block wx:else>
    <!-- 按钮行 -->
    <view class="nav-row">
      <button class="nav-btn follow-btn" bindtap="goFollow">
        <text class="btn-emoji">💗</text>
        <text>关注</text>
      </button>
      <button class="nav-btn history-btn" bindtap="goHistory">
        <text class="btn-emoji">📋</text>
        <text>历史</text>
      </button>
      <button class="nav-btn rank-btn" bindtap="goRank">
        <text class="btn-emoji">🏆</text>
        <text>排名</text>
      </button>
    </view>

    <!-- 第一行：交际舞 + 广场舞 -->
    <view class="category-row">
      <button class="big-cat-btn ballroom-btn {{shaking.ballroom ? 'pressed shaking' : ''}}" bindtap="goBallroom">
        <text class="big-cat-emoji">💫</text>
        <text>交际舞</text>
      </button>
      <button class="big-cat-btn square-btn {{shaking.square ? 'pressed shaking' : ''}}" bindtap="goSquare">
        <text class="big-cat-emoji">🎀</text>
        <text>广场舞</text>
      </button>
    </view>

    <!-- 第二行：民族舞 + 养生保健 -->
    <view class="category-row">
      <button class="big-cat-btn folk-btn {{shaking.folk ? 'pressed shaking' : ''}}" bindtap="goFolk">
        <text class="big-cat-emoji">🏮</text>
        <text>民族舞</text>
      </button>
      <button class="big-cat-btn health-btn {{shaking.health ? 'pressed shaking' : ''}}" bindtap="goHealth">
        <text class="big-cat-emoji">🍃</text>
        <text>养生操</text>
      </button>
    </view>
  </block>

  <!-- 测试按钮：选视频上传到云存储并播放 -->
  <button class="test-upload-btn" bindtap="testUpload" disabled="{{testing}}">
    {{testing ? '上传中 ' + uploadPercent + '%' : '测试上传并播放视频'}}
  </button>
  <view wx:if="{{testing}}" class="upload-progress">
    正在上传到云存储… {{uploadPercent}}%
  </view>
</view>

<!-- Debug 入口：姿态识别 -->
<view class="debug-gear {{shaking.debug ? 'gear-spin' : ''}}" bindtap="goPose">
  <text class="debug-gear-icon">⚙️</text>
</view>
