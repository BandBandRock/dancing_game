/* pages/shared/shared.wxss 分享落地页 */
page {
  background: linear-gradient(180deg, #1a1a2e 0%, #16213e 100%);
  min-height: 100vh;
}
.page {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 40rpx 60rpx;
}

/* 简介卡片 */
.card {
  width: 100%;
  background: rgba(255, 255, 255, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  border-radius: 28rpx;
  padding: 48rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
}
.card-title {
  font-size: 44rpx;
  font-weight: 800;
  color: #fff;
  text-align: center;
}
.card-score {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: linear-gradient(135deg, #ff7e5f, #feb47b);
  padding: 24rpx 48rpx;
  border-radius: 20rpx;
  gap: 4rpx;
}
.score-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
}
.score-num {
  font-size: 72rpx;
  font-weight: 800;
  color: #fff;
}
.card-meta {
  display: flex;
  align-items: center;
}
.meta-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.6);
}

/* 操作按钮 */
.actions {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  margin-top: 56rpx;
}
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 32rpx 0;
  border-radius: 20rpx;
  font-size: 32rpx;
  font-weight: 600;
}
.btn-play {
  background: rgba(255, 255, 255, 0.12);
  color: #fff;
  border: 1rpx solid rgba(255, 255, 255, 0.2);
}
.btn-dance {
  background: linear-gradient(135deg, #ff7e5f, #feb47b);
  color: #fff;
}
.btn-icon {
  font-size: 36rpx;
}
.btn-text {
  font-size: 32rpx;
}

/* 底部链接 */
.home-link {
  margin-top: 48rpx;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.5);
}

/* 播放浮层 */
.play-mask {
  position: fixed;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  z-index: 200;
  background: rgba(0, 0, 0, 0.92);
  display: flex;
  align-items: center;
  justify-content: center;
}
.play-panel {
  width: 96%;
  max-height: 90vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}
.play-row {
  width: 100%;
  display: flex;
  flex-direction: row;
  gap: 8rpx;
}
.play-col {
  flex: 1;
  position: relative;
  background: #111;
  border-radius: 12rpx;
  overflow: hidden;
  aspect-ratio: 9/16;
}
.play-label {
  position: absolute;
  top: 10rpx;
  left: 10rpx;
  z-index: 10;
  background: rgba(0, 0, 0, 0.6);
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}
.play-video {
  width: 100%;
  height: 100%;
}
.play-empty {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #555;
  font-size: 24rpx;
}
.play-close {
  margin-top: 16rpx;
  padding: 16rpx 48rpx;
  background: rgba(255, 255, 255, 0.15);
  color: #fff;
  font-size: 28rpx;
  border-radius: 40rpx;
}
