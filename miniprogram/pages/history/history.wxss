/**history.wxss 我的跳舞历史**/
page {
  height: 100vh;
  width: 100vw;
  max-width: 100vw;
  overflow-x: hidden;
  display: flex;
  flex-direction: column;
  background: #f5f5f5;
}

.page {
  flex: 1;
  width: 100%;
  max-width: 100vw;
  overflow-x: hidden;
  padding: 24rpx 32rpx;
  box-sizing: border-box;
}

/* 顶部返回首页按钮（常驻，真机可见可点） */
.topbar {
  padding: 12rpx 32rpx 0;
  background: #f5f5f5;
}
.home-btn {
  display: inline-block;
  padding: 14rpx 28rpx;
  background: #fff;
  color: #ff7e5f;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 999rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.06);
}
.home-btn:active {
  background: #fff1ec;
}

/* 统计卡片 */
.stats-card {
  position: sticky;
  top: 0;
  z-index: 5;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #ff7e5f, #feb47b);
  border-radius: 24rpx;
  padding: 40rpx 20rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 6rpx 24rpx rgba(255, 126, 95, 0.3);
}
/* 删除（垃圾桶）图标：选择模式下高亮 */
.trash {
  position: absolute;
  right: 28rpx;
  top: 50%;
  margin-top: -36rpx;
  width: 72rpx;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  font-size: 38rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.18);
  transition: transform 0.15s ease, background 0.15s ease;
}
.trash.active {
  transform: scale(1.12);
  background: rgba(255, 255, 255, 0.5);
}
.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}
.stat-num {
  font-size: 52rpx;
  font-weight: 700;
  color: #fff;
}
.stat-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
}

/* 列表标题 / 选择模式操作条 */
.list-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}
.select-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}
.select-cancel,
.select-one {
  font-size: 30rpx;
  color: #ff7e5f;
}
.select-info {
  font-size: 28rpx;
  color: #666;
}

/* 记录列表 */
.list-area {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding-bottom: 24rpx;
}
.record-card {
  position: relative;
  display: flex;
  align-items: flex-start;
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  max-width: 100%;
  padding: 28rpx 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}
/* 选择模式下每项左侧的小圆圈 */
.pick-circle {
  flex: none;
  width: 40rpx;
  height: 40rpx;
  margin: 6rpx 16rpx 0 0;
  border-radius: 50%;
  border: 3rpx solid #ccc;
  background: #fff;
  box-sizing: border-box;
}
.pick-circle.on {
  border-color: #ff7e5f;
  background: #ff7e5f;
}
.record-main {
  flex: 1;
  min-width: 0;
  max-width: 100%;
  overflow: hidden;
  display: flex;
  flex-direction: row;
  gap: 20rpx;
}
/* 左侧封面 */
.record-cover {
  position: relative;
  flex: none;
  width: 200rpx;
  height: 280rpx;
  border-radius: 16rpx;
  overflow: hidden;
  background: linear-gradient(135deg, #667eea, #764ba2);
}
.cover-video {
  width: 100%;
  height: 100%;
}
.cover-ph {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}
.cover-emoji {
  font-size: 60rpx;
}
.cover-play {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.45);
  color: #fff;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
/* 右侧信息 */
.record-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 12rpx;
}
.record-song {
  font-size: 34rpx;
  font-weight: 700;
  color: #222;
}
.record-score {
  font-size: 28rpx;
  font-weight: 600;
  color: #ff7e5f;
  background: rgba(255, 126, 95, 0.12);
  padding: 4rpx 14rpx;
  border-radius: 16rpx;
  align-self: flex-start;
}
.record-time {
  display: flex;
  align-items: center;
  gap: 10rpx;
}
.record-date,
.record-clock {
  font-size: 26rpx;
  color: #999;
}
.record-dot {
  color: #ccc;
}

/* 操作按钮 */
.record-actions {
  display: flex;
  flex-direction: row;
  gap: 12rpx;
  margin-top: 12rpx;
}
.rec-btn {
  font-size: 22rpx;
  font-weight: 600;
  padding: 8rpx 20rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.rec-share {
  background: rgba(255, 126, 95, 0.1) !important;
  color: #ff7e5f !important;
  border: 1rpx solid rgba(255, 126, 95, 0.3);
  font-size: 22rpx !important;
  line-height: 1.4;
  padding: 8rpx 20rpx !important;
  margin: 0 !important;
}
.rec-redance {
  background: linear-gradient(135deg, #ff7e5f, #feb47b);
  color: #fff;
}

/* 调试齿轮：视频右上角，点击弹出 fileId / 骨骼信息 */
.debug-gear {
  position: absolute;
  right: 20rpx;
  top: 20rpx;
  width: 56rpx;
  height: 56rpx;
  line-height: 56rpx;
  text-align: center;
  font-size: 32rpx;
  color: #fff;
  background: rgba(0, 0, 0, 0.4);
  border-radius: 50%;
}

/* 清空按钮 */
.clear-btn {
  margin: 24rpx 0 60rpx;
  text-align: center;
  font-size: 30rpx;
  color: #999;
  padding: 22rpx 0;
  background: #fff;
  border-radius: 20rpx;
}

/* 长按 5s 调试信息浮层 */
.debug-mask {
  position: fixed;
  left: 0;
  top: 0;
  right: 0;
  bottom: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.55);
}
.debug-box {
  width: 84%;
  max-width: 640rpx;
  background: #1e1e1e;
  color: #e6e6e6;
  border-radius: 20rpx;
  padding: 36rpx 32rpx 28rpx;
  box-shadow: 0 12rpx 60rpx rgba(0, 0, 0, 0.5);
}
.debug-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #4fd1c5;
  margin-bottom: 22rpx;
}
.debug-row {
  display: flex;
  flex-direction: column;
  margin-bottom: 18rpx;
}
.debug-k {
  font-size: 24rpx;
  color: #9aa0a6;
  margin-bottom: 6rpx;
}
.debug-v {
  font-size: 28rpx;
  line-height: 1.5;
  word-break: break-all;
  color: #fff;
}
.debug-v.mono {
  font-family: "SF Mono", Menlo, Consolas, monospace;
}
.debug-close {
  margin-top: 12rpx;
  text-align: center;
  font-size: 30rpx;
  color: #4fd1c5;
  padding: 16rpx 0;
  border-top: 1rpx solid rgba(255, 255, 255, 0.12);
}
.debug-demo {
  margin-top: 18rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: 700;
  color: #06281f;
  background: #5DCAA5;
  padding: 18rpx 0;
  border-radius: 12rpx;
}

/* 空态 */
.empty-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
  gap: 16rpx;
}
.empty-emoji {
  font-size: 80rpx;
}
.empty-text {
  font-size: 30rpx;
  color: #999;
}

