<!--history.wxml 我的跳舞历史-->
<navigation-bar title="我的跳舞历史" back="{{false}}" color="black" background="#FFF"></navigation-bar>
<!-- 明确的返回首页按钮（普通 view，真机 Skyline 下稳定可见可点，不依赖 mask 图标） -->
<view class="topbar">
  <view class="home-btn" bindtap="onGoHome">🏠 返回首页</view>
</view>
<scroll-view class="page" scroll-y>
  <!-- 统计卡片 -->
  <view class="stats-card">
    <view class="stat-item">
      <text class="stat-num">{{totalCount}}</text>
      <text class="stat-label">跳舞次数</text>
    </view>
    <!-- 垃圾桶：点一下进入选择模式；选择模式下再点即删除已选 -->
    <view class="trash {{selecting ? 'active' : ''}}" wx:if="{{list.length > 0}}" bindtap="onTrashTap">🗑️</view>
  </view>

  <!-- 列表标题 / 选择模式操作条 -->
  <view class="list-title" wx:if="{{!selecting}}">跳舞记录</view>
  <view class="select-bar" wx:else>
    <text class="select-cancel" bindtap="onCancel">取消</text>
    <text class="select-info">已选 {{selectedCount}} 项</text>
    <text class="select-one" bindtap="onTrashTap">删除</text>
  </view>

  <!-- 跳舞记录列表 -->
  <view class="list-area" wx:if="{{list.length > 0}}">
    <view class="record-card" wx:for="{{list}}" wx:key="id" data-id="{{item.id}}">
      <!-- 选择模式下左侧的小圆圈：点一下切换选中 -->
      <view
        wx:if="{{selecting}}"
        class="pick-circle {{selectedMap[item.id] ? 'on' : ''}}"
        data-id="{{item.id}}"
        catchtap="onToggleCircle"
      ></view>
      <view class="record-main" bindtap="onPlay" data-id="{{item.id}}">
        <!-- 封面区域 -->
        <view class="record-cover">
          <video
            wx:if="{{item.coverUrl}}"
            class="cover-video"
            src="{{item.coverUrl}}"
            autoplay="{{false}}"
            controls="{{false}}"
            show-center-play-btn="{{false}}"
            object-fit="cover"
            muted="{{true}}"
          ></video>
          <view wx:else class="cover-ph">
            <text class="cover-emoji">🎥</text>
          </view>
          <view class="cover-play">▶</view>

        </view>
        <!-- 信息区域 -->
        <view class="record-info">
          <text class="record-song">{{item.song}}</text>
          <text class="record-score">{{item.scoreText}}</text>
          <view class="record-time">
            <text class="record-date">{{item.dateText}}</text>
            <text class="record-dot">·</text>
            <text class="record-clock">{{item.timeText}}</text>
          </view>
          <!-- 操作按钮 -->
          <view class="record-actions">
            <button class="rec-btn rec-share" open-type="share" data-id="{{item.id}}" catchtap="noop">📤 分享</button>
            <view class="rec-btn rec-redance" catchtap="onRedance" data-id="{{item.id}}">🕺 再跳一次</view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <view class="empty-tip" wx:else>
    <text class="empty-emoji">📭</text>
    <text class="empty-text">还没有跳舞记录，去跳一支吧！</text>
  </view>

  <view wx:if="{{list.length > 0}}" class="clear-btn" bindtap="onClear">清空历史记录</view>

  <!-- 长按 5s 调试信息浮层 -->
  <view wx:if="{{debugShow}}" class="debug-mask" bindtap="onDebugClose">
    <view class="debug-box" catchtap="noop">
      <view class="debug-title">调试信息（长按 5s）</view>
      <view class="debug-row">
        <text class="debug-k">歌曲</text>
        <text class="debug-v">{{debugSong}}</text>
      </view>
      <view class="debug-row">
        <text class="debug-k">视频 fileId</text>
        <text class="debug-v mono" user-select="{{true}}" selectable="{{true}}">{{debugVideo}}</text>
      </view>
      <view class="debug-row">
        <text class="debug-k">骨骼JSON fileId</text>
        <text class="debug-v mono" user-select="{{true}}" selectable="{{true}}">{{debugSkeleton}}</text>
      </view>
      <view class="debug-row">
        <text class="debug-k">记录 id</text>
        <text class="debug-v mono">{{debugId}}</text>
      </view>
      <view class="debug-demo" bindtap="onOpenSkeleton">▶ 呈现骨骼视频</view>
      <view class="debug-close" bindtap="onDebugClose">关闭</view>
    </view>
  </view>
</scroll-view>
