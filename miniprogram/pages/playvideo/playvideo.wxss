/* pages/playvideo/playvideo.wxss 横屏：左侧双视频 + 右侧信息面板 */
page {
  width: 100vw;
  height: 100vh;
  overflow: hidden;
}
.root {
  position: fixed;
  left: 0;
  top: 0;
  width: 100vw;
  height: 100vh;
  background: #0a0a0a;
  display: flex;
  flex-direction: row;
  overflow: hidden;
}

/* 左侧双视频区域：占约 70% 宽度 */
.left-area {
  flex: none;
  width: 70%;
  height: 100%;
  display: flex;
  flex-direction: row;
  gap: 4rpx;
}
.loading-area {
  align-items: center;
  justify-content: center;
}
.loading-text {
  color: #999;
  font-size: 28rpx;
}

/* 每列视频 */
.video-col {
  flex: 1;
  position: relative;
  display: flex;
  flex-direction: column;
  background: #111;
  overflow: hidden;
}
.col-label {
  position: absolute;
  top: 10rpx;
  left: 10rpx;
  z-index: 10;
  background: rgba(0, 0, 0, 0.65);
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}
.col-video {
  width: 100%;
  height: 100%;
}
.col-empty {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #555;
  font-size: 24rpx;
}

/* 右侧信息面板：占 30% 宽度，内容居中不溢出 */
.right-panel {
  flex: 1;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 16rpx 16rpx;
  gap: 20rpx;
  overflow: hidden;
  box-sizing: border-box;
}
.info-block {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}
.info-song {
  font-size: 26rpx;
  font-weight: 700;
  color: #fff;
  text-align: center;
  word-break: break-all;
  max-width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
}
.score-block {
  background: linear-gradient(135deg, #ff7e5f, #feb47b);
  padding: 12rpx 28rpx;
  border-radius: 16rpx;
}
.score-label {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.8);
}
.score-num {
  font-size: 48rpx;
  font-weight: 800;
  color: #fff;
}
.info-date {
  font-size: 22rpx;
  color: #aaa;
}
.info-time {
  font-size: 20rpx;
  color: #888;
}
.info-rate {
  font-size: 20rpx;
  color: #feb47b;
  font-weight: 600;
}

/* 操作按钮 */
.action-btns {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  width: 100%;
}
.action-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 14rpx 0;
  border-radius: 12rpx;
  font-size: 22rpx;
  font-weight: 600;
}
.share-btn {
  background: rgba(255, 255, 255, 0.12) !important;
  color: #fff !important;
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  font-size: 22rpx !important;
  line-height: 1.4;
  padding: 14rpx 0 !important;
  margin: 0 !important;
}
.redance-btn {
  background: linear-gradient(135deg, #ff7e5f, #feb47b);
  color: #fff;
}

/* 退出按钮（左上角） */
.exit-btn {
  position: absolute;
  top: 12rpx;
  left: 16rpx;
  z-index: 100;
  width: 56rpx;
  height: 56rpx;
  line-height: 56rpx;
  text-align: center;
  border-radius: 50%;
  background-color: rgba(0, 0, 0, 0.55);
}
.exit-icon {
  font-size: 30rpx;
  color: #fff;
}
