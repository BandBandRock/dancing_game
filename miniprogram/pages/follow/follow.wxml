<!--follow.wxml-->
<navigation-bar title="关注 - 收藏舞曲" back="{{true}}" color="black" background="#FFF"></navigation-bar>
<scroll-view class="page" scroll-y type="list">
  <!-- 搜索条 -->
  <view class="search-bar">
    <text class="search-icon">🔍</text>
    <input class="search-input" placeholder="搜索收藏的舞曲..." bindinput="onSearchInput" value="{{keyword}}" />
  </view>

  <!-- 列表 -->
  <view class="list-area" wx:if="{{filteredList.length > 0}}">
    <view
      class="music-item"
      wx:for="{{filteredList}}"
      wx:key="id"
    >
      <view class="item-left">
        <view class="item-cover">{{item.emoji}}</view>
        <view class="item-info">
          <text class="item-title">{{item.title}}</text>
          <text class="item-sub">{{item.style}} · {{item.duration}}</text>
        </view>
      </view>
      <view class="item-right">
        <text class="item-heart {{item.liked ? 'liked' : ''}}" data-id="{{item.id}}" bindtap="toggleLike">{{item.liked ? '❤️' : '🤍'}}</text>
      </view>
    </view>
  </view>

  <view class="empty-tip" wx:else>
    <text class="empty-emoji">🎵</text>
    <text class="empty-text">暂无收藏舞曲</text>
    <text class="empty-hint">去首页选择舞种探索更多</text>
  </view>
</scroll-view>
