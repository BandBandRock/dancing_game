<!--follow.wxml-->
<navigation-bar title="收藏 - 最爱舞曲" back="{{true}}" color="black" background="#FFF"></navigation-bar>
<scroll-view class="page" scroll-y>
  <!-- 搜索条 -->
  <view class="search-bar">
    <text class="search-icon">🔍</text>
    <input class="search-input" placeholder="搜索最爱的舞曲..." bindinput="onSearchInput" value="{{keyword}}" />
  </view>

  <!-- 列表 -->
  <view class="list-area" wx:if="{{filteredList.length > 0}}">
    <view
      class="music-item"
      wx:for="{{filteredList}}"
      wx:key="favoritedAt"
      bindtap="onMusicTap"
      data-index="{{index}}"
    >
      <view class="item-left">
        <view class="item-cover">💃</view>
        <view class="item-info">
          <text class="item-title">{{item.name}}</text>
          <text class="item-sub">🕐 时长：{{item.duration}}</text>
        </view>
      </view>
      <view class="item-right">
        <text class="item-heart liked" data-index="{{index}}" bindtap="removeFavorite">❤️</text>
      </view>
    </view>
  </view>

  <view class="empty-tip" wx:else>
    <text class="empty-emoji">🎵</text>
    <text class="empty-text">暂无最爱舞曲</text>
    <text class="empty-hint">在歌曲列表中点亮❤️即可收藏</text>
  </view>
</scroll-view>
