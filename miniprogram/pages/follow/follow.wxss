/**follow.wxss**/
page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f5f5f5;
}

.page {
  flex: 1;
  padding: 24rpx 32rpx;
}

/* 搜索条 */
.search-bar {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 40rpx;
  padding: 12rpx 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.search-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  height: 64rpx;
  line-height: 64rpx;
}

/* 列表 */
.list-area {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.music-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.item-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
  flex: 1;
}

.item-cover {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  background: #f8f8f8;
  border-radius: 16rpx;
}

.item-info {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.item-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.item-sub {
  font-size: 24rpx;
  color: #999;
}

.item-right {
  padding: 12rpx;
}

.item-heart {
  font-size: 40rpx;
  transition: transform 0.2s;
}

.item-heart:active {
  transform: scale(1.3);
}

.item-heart.liked {
  animation: heartPop 0.3s ease;
}

@keyframes heartPop {
  0% { transform: scale(1); }
  50% { transform: scale(1.4); }
  100% { transform: scale(1); }
}

/* 空态 */
.empty-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
  gap: 16rpx;
}

.empty-emoji {
  font-size: 80rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #999;
}

.empty-hint {
  font-size: 24rpx;
  color: #ccc;
}
