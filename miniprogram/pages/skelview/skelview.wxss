/* skelview.wxss 横屏双视频对比 + 骨骼叠加 */
.wrap {
  position: relative;
  width: 100vw;
  height: 100vh;
  background: #000;
  display: flex;
  flex-direction: row;
}
/* 两列各占一半；无示例视频时 user 占满整屏 */
.col {
  position: relative;
  height: 100%;
  width: 50%;
  box-sizing: border-box;
}
.col.user {
  border-left: 2rpx solid rgba(255, 255, 255, 0.12);
}
.wrap.single .col.user {
  width: 100%;
  border-left: none;
}
.player {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
}
/* 骨骼叠加层：铺满用户视频列、不拦截触摸 */
.overlay {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
}
/* 列标签（示例 / 我的） */
.tag {
  position: absolute;
  left: 16rpx;
  bottom: 16rpx;
  padding: 4rpx 16rpx;
  font-size: 22rpx;
  color: #fff;
  background: rgba(0, 0, 0, 0.45);
  border-radius: 20rpx;
  z-index: 5;
}
.topbar {
  position: absolute;
  left: 0;
  top: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 80rpx 32rpx 20rpx;
  z-index: 10;
}
.back {
  width: 64rpx;
  height: 64rpx;
  line-height: 64rpx;
  text-align: center;
  font-size: 40rpx;
  color: #fff;
  background: rgba(0, 0, 0, 0.4);
  border-radius: 50%;
}
.title {
  flex: 1;
  text-align: center;
  color: #fff;
  font-size: 30rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.6);
}
.mirror-btn {
  padding: 10rpx 24rpx;
  font-size: 26rpx;
  color: #fff;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 30rpx;
}
.mirror-btn.on {
  background: #5DCAA5;
  color: #06281f;
}
.err {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  max-width: 80%;
  text-align: center;
  color: #ffd43b;
  font-size: 28rpx;
  background: rgba(0, 0, 0, 0.6);
  padding: 24rpx 32rpx;
  border-radius: 16rpx;
  z-index: 20;
}
/* 调试角标：展示原视频信息（分辨率 / 骨骼帧数 / 进度），不挡主体 */
.debug {
  position: absolute;
  left: 50%;
  top: 150rpx;
  transform: translateX(-50%);
  padding: 6rpx 20rpx;
  font-size: 22rpx;
  color: #5DCAA5;
  background: rgba(0, 0, 0, 0.5);
  border-radius: 24rpx;
  z-index: 15;
  white-space: nowrap;
}
