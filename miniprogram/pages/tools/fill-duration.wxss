/* pages/tools/fill-duration.wxss */
.page { padding: 40rpx; }
.title { font-size: 36rpx; font-weight: 700; margin-bottom: 24rpx; }
.status { font-size: 28rpx; color: #666; margin-bottom: 16rpx; }
.current { font-size: 26rpx; color: #333; margin-bottom: 24rpx; }
.start-btn { margin: 24rpx 0; }
.result-list { margin-top: 24rpx; }
.result-item { display: flex; justify-content: space-between; padding: 12rpx 0; border-bottom: 1rpx solid #eee; font-size: 26rpx; }
.dur { color: #ff7e5f; font-weight: 600; }
.probe-video { width: 1rpx; height: 1rpx; position: fixed; left: -100rpx; top: -100rpx; opacity: 0; }
